{
  "name": "catalogo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint . --ignore-pattern .next/** --ignore-pattern node_modules/** --ignore-pattern out/** --ignore-pattern build/**",
    "lint:fix": "eslint . --fix --ignore-pattern .next/** --ignore-pattern node_modules/** --ignore-pattern out/** --ignore-pattern build/**",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run lint",
    "migrate:clientes": "psql \"$DATABASE_URL\" -f database/create_clientes_table.sql || echo 'ERROR: set $DATABASE_URL (pSQL) or run SQL in Supabase dashboard'",
    "migrate:ventas": "psql \"$DATABASE_URL\" -f database/add_cliente_nit_to_ventas.sql || echo 'ERROR: set $DATABASE_URL (pSQL) or run SQL in Supabase dashboard'"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/supabase-js": "^2.57.4",
    "@vercel/speed-insights": "^1.2.0",
    "chart.js": "^4.5.0",
    "class-variance-authority": "^0.7.0",
    "dompurify": "^3.3.1",
    "firebase": "^12.3.0",
    "framer-motion": "^12.29.2",
    "js-yaml": "^4.1.1",
    "jspdf": "^4.0.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.544.0",
    "next": "^16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.1.0",
    "react-barcode": "^1.6.1",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "19.1.0",
    "react-facebook-pixel": "^1.0.4",
    "react-hot-toast": "^2.6.0",
    "react-toastify": "^11.0.5",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.3.1",
    "tar": "^7.5.7",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
    "tailwindcss": "^4",
    "typescript": "5.9.3"
  }
}
